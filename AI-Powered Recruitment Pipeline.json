    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.message?.content || '';\n\nconst cleaned = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n\nlet ai;\ntry {\n  ai = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('Invalid AI JSON: ' + cleaned);\n}\n\nreturn [{ json: { ...ai, candidate: $('New Application Webhook').first().json } }];"
      },
